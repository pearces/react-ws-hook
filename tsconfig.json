{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./lib",
    "strictNullChecks": true,
    "jsx": "react",
    "target": "es2022",
    "allowJs": true,
    "esModuleInterop": true,
    "strict": true,
    "removeComments": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node", "jest"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib", "coverage"],
  "tsc-alias": {
    "resolveFullPaths": true
  }
}
